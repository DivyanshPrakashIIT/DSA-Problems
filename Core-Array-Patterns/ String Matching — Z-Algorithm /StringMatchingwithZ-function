#include <bits/stdc++.h>
using namespace std;

vector<int> zFunction(string s) {

    int n = s.size();
    vector<int> z(n);

    int l = 0, r = 0;

    for (int i = 1; i < n; i++) {

        if (i <= r)
            z[i] = min(r - i + 1, z[i - l]);

        while (i + z[i] < n && s[z[i]] == s[i + z[i]])
            z[i]++;

        if (i + z[i] - 1 > r) {
            l = i;
            r = i + z[i] - 1;
        }
    }

    return z;
}

int main() {

    string s;
    cin >> s;

    vector<int> z = zFunction(s);

    int n = s.size();

    int mx = 0;
    int ans = 0;

    for (int i = 1; i < n; i++) {

        if (i + z[i] == n && mx >= z[i])
            ans = max(ans, z[i]);

        mx = max(mx, z[i]);
    }

    if (ans == 0)
        cout << "Just a legend";
    else
        cout << s.substr(0, ans);
}
