class StreamChecker {
public:

    struct TrieNode {
        TrieNode* child[26];
        bool isEnd;

        TrieNode() {
            for (int i = 0; i < 26; i++)
                child[i] = nullptr;

            isEnd = false;
        }
    };

    TrieNode* root;
    string stream;
    int maxLen;

    StreamChecker(vector<string>& words) {

        root = new TrieNode();
        maxLen = 0;

        for (string word : words) {

            maxLen = max(maxLen, (int)word.size());

            reverse(word.begin(), word.end());

            TrieNode* node = root;

            for (char ch : word) {

                int idx = ch - 'a';

                if (node->child[idx] == nullptr)
                    node->child[idx] = new TrieNode();

                node = node->child[idx];
            }

            node->isEnd = true;
        }
    }

    bool query(char letter) {

        stream.push_back(letter);

        TrieNode* node = root;

        for (int i = stream.size() - 1;
             i >= 0 && stream.size() - i <= maxLen;
             i--) {

            int idx = stream[i] - 'a';

            if (node->child[idx] == nullptr)
                return false;

            node = node->child[idx];

            if (node->isEnd)
                return true;
        }

        return false;
    }
};
