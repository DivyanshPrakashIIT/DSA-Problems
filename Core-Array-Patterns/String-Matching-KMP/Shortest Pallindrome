class Solution {
public:
    vector<int> buildLPS(string s) {
        int n = s.size();
        vector<int> lps(n, 0);

        int len = 0;
        int i = 1;

        while (i < n) {
            if (s[i] == s[len]) {
                len++;
                lps[i] = len;
                i++;
            } else {
                if (len != 0) {
                    len = lps[len - 1];
                } else {
                    lps[i] = 0;
                    i++;
                }
            }
        }

        return lps;
    }

    string shortestPalindrome(string s) {
        string rev = s;
        reverse(rev.begin(), rev.end());

        string temp = s + "#" + rev;

        vector<int> lps = buildLPS(temp);

        int len = lps.back();

        string remain = s.substr(len);

        reverse(remain.begin(), remain.end());

        return remain + s;
    }
};
