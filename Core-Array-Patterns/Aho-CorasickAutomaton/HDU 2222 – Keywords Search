#include <bits/stdc++.h>
using namespace std;

struct Node {
    int next[26];
    int fail;
    int cnt;

    Node() {
        memset(next, -1, sizeof(next));
        fail = 0;
        cnt = 0;
    }
};

vector<Node> trie;

void insertWord(string &s) {

    int cur = 0;

    for (char ch : s) {

        int c = ch - 'a';

        if (trie[cur].next[c] == -1) {
            trie[cur].next[c] = trie.size();
            trie.push_back(Node());
        }

        cur = trie[cur].next[c];
    }

    trie[cur].cnt++;
}

void buildFailure() {

    queue<int> q;

    for (int c = 0; c < 26; c++) {

        if (trie[0].next[c] != -1) {

            trie[trie[0].next[c]].fail = 0;
            q.push(trie[0].next[c]);
        }
        else {
            trie[0].next[c] = 0;
        }
    }

    while (!q.empty()) {

        int u = q.front();
        q.pop();

        for (int c = 0; c < 26; c++) {

            if (trie[u].next[c] != -1) {

                trie[trie[u].next[c]].fail =
                    trie[trie[u].fail].next[c];

                q.push(trie[u].next[c]);
            }
            else {

                trie[u].next[c] =
                    trie[trie[u].fail].next[c];
            }
        }
    }
}

int query(string &text) {

    int cur = 0;
    int ans = 0;

    for (char ch : text) {

        cur = trie[cur].next[ch - 'a'];

        int temp = cur;

        while (temp && trie[temp].cnt != -1) {

            ans += trie[temp].cnt;

            trie[temp].cnt = -1;

            temp = trie[temp].fail;
        }
    }

    return ans;
}

int main() {

    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {

        trie.clear();
        trie.push_back(Node());

        int n;
        cin >> n;

        while (n--) {

            string s;
            cin >> s;

            insertWord(s);
        }

        buildFailure();

        string text;
        cin >> text;

        cout << query(text) << "\n";
    }
}
