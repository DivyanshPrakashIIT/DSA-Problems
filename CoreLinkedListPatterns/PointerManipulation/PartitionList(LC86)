class Solution {
public:
    ListNode* partition(ListNode* head, int x) {
        ListNode* smallHead = new ListNode(0);
        ListNode* largeHead = new ListNode(0);
        
        ListNode* small = smallHead;
        ListNode* large = largeHead;
        
        ListNode* curr = head;
        
        while (curr != nullptr) {
            if (curr->val < x) {
                small->next = curr;  
                small = small->next; 
            } else {
                large->next = curr;  
                large = large->next; // <-- FIX: Ekdum simple standard step
            }
            curr = curr->next; 
        }
        
        large->next = nullptr; // Cycle se bachne ke liye last node ko block kiya
        small->next = largeHead->next; // Dono lists ko merge kiya
        
        ListNode* newHead = smallHead->next;
        
        delete smallHead;
        delete largeHead;
        
        return newHead;
    }
};
