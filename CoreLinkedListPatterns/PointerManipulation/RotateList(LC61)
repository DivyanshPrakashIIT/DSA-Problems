class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        // Edge cases: Agar list khali hai, ek hi node hai, ya rotation 0 hai
        if (!head || !head->next || k == 0) return head;
        
        // Step 1: Find the length of the list and reach the tail node
        ListNode* tail = head;
        int length = 1;
        while (tail->next != nullptr) {
            tail = tail->next;
            length++;
        }
        
        // Step 2: Handle cases where k >= length
        k = k % length;
        if (k == 0) return head; // Agar rotation zero ban jaye, kuch badalne ki zaroorat nahi
        
        // Step 3: Connect tail to head to form a circular list
        tail->next = head;
        
        // Step 4: Find the new tail position (length - k steps from start)
        ListNode* newTail = head;
        for (int i = 1; i < length - k; i++) {
            newTail = newTail->next;
        }
        
        // Step 5: Break the circle and update head
        ListNode* newHead = newTail->next;
        newTail->next = nullptr;
        
        return newHead;
    }
};
