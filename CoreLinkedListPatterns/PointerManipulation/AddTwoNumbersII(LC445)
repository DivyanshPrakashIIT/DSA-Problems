class Solution {
private:
    // Helper function to reverse a linked list in-place
    ListNode* reverseList(ListNode* head) {
        ListNode* prev = nullptr;
        ListNode* curr = head;
        while (curr != nullptr) {
            ListNode* forward = curr->next;
            curr->next = prev;
            prev = curr;
            curr = forward;
        }
        return prev;
    }

public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        // 1. Dono lists ko reverse karo
        l1 = reverseList(l1);
        l2 = reverseList(l2);
        
        ListNode* dummyHead = new ListNode(0);
        ListNode* curr = dummyHead;
        int carry = 0;
        
        // 2. Normal addition loop (Part 1 wala)
        while (l1 != nullptr || l2 != nullptr || carry != 0) {
            int sum = carry;
            if (l1 != nullptr) { sum += l1->val; l1 = l1->next; }
            if (l2 != nullptr) { sum += l2->val; l2 = l2->next; }
            
            carry = sum / 10;
            curr->next = new ListNode(sum % 10);
            curr = curr->next;
        }
        
        ListNode* res = dummyHead->next;
        delete dummyHead;
        
        // 3. Result ko wapas reverse karke seedha karo
        return reverseList(res);
    }
};
