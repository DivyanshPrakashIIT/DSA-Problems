class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        // Dummy node banaya taaki agar head delete ho toh dikkat na aaye
        ListNode* dummy = new ListNode(0, head);
        ListNode* prev = dummy;
        ListNode* curr = head;
        
        while (curr != nullptr) {
            // Agar duplicate segment milta hai
            if (curr->next != nullptr && curr->val == curr->next->val) {
                // Jab tak same value wale nodes hain, curr ko aage badhaate jao
                while (curr->next != nullptr && curr->val == curr->next->val) {
                    ListNode* temp = curr;
                    curr = curr->next;
                    delete temp; // Memory free karte chalna achhi practice hai
                }
                
                // Ek aakhiri duplicate node abhi bhi curr par hai, use bhi skip karo
                ListNode* lastDuplicate = curr;
                prev->next = curr->next; 
                curr = curr->next;
                delete lastDuplicate;
                
            } else {
                // Agar koi duplicate nahi mila, toh prev ko normal badhao
                prev = prev->next;
                curr = curr->next;
            }
        }
        
        ListNode* newHead = dummy->next;
        delete dummy; // Dummy ki memory free ki
        return newHead;
    }
};
