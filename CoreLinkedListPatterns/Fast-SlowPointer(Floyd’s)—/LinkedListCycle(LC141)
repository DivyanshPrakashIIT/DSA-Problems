class Solution {
public:
    bool hasCycle(ListNode *head) {
        ListNode* rabbit = head;
        ListNode* turtle = head;
        while(rabbit != NULL && rabbit->next != NULL){
            rabbit = rabbit->next->next;
            turtle = turtle->next;
            if(rabbit == turtle){
                return true;
            }
        }
        return false;
    }
};
