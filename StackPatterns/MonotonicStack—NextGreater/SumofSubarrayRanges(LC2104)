#include <vector>
#include <stack>

using namespace std;

class Solution {
public:
    long long subArrayRanges(vector<int>& nums) {
        return getSum(nums, true) - getSum(nums, false);
    }

private:
    long long getSum(vector<int>& nums, bool isMax) {
        int n = nums.size();
        long long total = 0;
        stack<int> st;

        for (int i = 0; i <= n; ++i) {
            while (!st.empty() && (i == n || (isMax ? nums[st.top()] < nums[i] : nums[st.top()] > nums[i]))) {
                int mid = st.top();
                st.pop();
                int leftBound = st.empty() ? -1 : st.top();
                int rightBound = i;

                long long count = (long long)(mid - leftBound) * (rightBound - mid);
                total += (long long)nums[mid] * count;
            }
            st.push(i);
        }
        return total;
    }
};
