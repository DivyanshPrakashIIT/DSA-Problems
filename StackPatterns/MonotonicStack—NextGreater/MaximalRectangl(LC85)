class Solution {
public:
    int maximalRectangle(vector<vector<char>>& matrix) {
        if (matrix.empty() || matrix[0].empty()) return 0;
        
        int rows = matrix.size();
        int cols = matrix[0].size();
        vector<int> heights(cols, 0);
        int maxArea = 0;
        
        for (int i = 0; i < rows; ++i) {
            // 1. Update the histogram heights for the current row
            for (int j = 0; j < cols; ++j) {
                if (matrix[i][j] == '1') {
                    heights[j] += 1; // Accumulate height if it's a '1'
                } else {
                    heights[j] = 0;  // Broken chain: height resets to 0
                }
            }
            
            // 2. Find the largest rectangle in the current histogram row
            maxArea = max(maxArea, largestRectangleArea(heights));
        }
        
        return maxArea;
    }

private:
    // Helper function: Monotonic Stack to find largest rectangle in a histogram
    int largestRectangleArea(vector<int>& heights) {
        stack<int> s;
        int maxArea = 0;
        int n = heights.size();
        
        for (int i = 0; i <= n; ++i) {
            // Use a dummy height of 0 at the end to flush out remaining elements in the stack
            int currentHeight = (i == n) ? 0 : heights[i];
            
            while (!s.empty() && currentHeight < heights[s.top()]) {
                int height = heights[s.top()];
                s.pop();
                
                // If stack is empty, the bar extends all the way to index 0
                int width = s.empty() ? i : i - s.top() - 1;
                maxArea = max(maxArea, height * width);
            }
            s.push(i);
        }
        
        return maxArea;
    }
};
