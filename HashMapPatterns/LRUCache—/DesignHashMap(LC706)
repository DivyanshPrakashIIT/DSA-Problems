#include <vector>
#include <list>
#include <algorithm>

using namespace std;

class MyHashMap {
private:
    // Choosing a prime number for bucket size significantly reduces hash collisions
    static const int BUCKET_SIZE = 10007;
    
    // The main storage: An array of lists containing {key, value} pairs
    vector<list<pair<int, int>>> buckets;

    // Internal hash function to map keys to bucket indices
    int getHashIndex(int key) {
        return key % BUCKET_SIZE;
    }

public:
    MyHashMap() {
        // Pre-allocate the buckets layout
        buckets.resize(BUCKET_SIZE);
    }
    
    void put(int key, int value) {
        int idx = getHashIndex(key);
        
        // Traverse the specific linked list at buckets[idx]
        for (auto& element : buckets[idx]) {
            if (element.first == key) {
                element.second = value; // Key found, update its value
                return;
            }
        }
        
        // Key not found, append the new pair to the list
        buckets[idx].push_back({key, value});
    }
    
    int get(int key) {
        int idx = getHashIndex(key);
        
        // Search for the key in the target bucket chain
        for (const auto& element : buckets[idx]) {
            if (element.first == key) {
                return element.second; // Return value if found
            }
        }
        
        return -1; // Return -1 if the key doesn't exist
    }
    
    void remove(int key) {
        int idx = getHashIndex(key);
        
        // Iterate using an explicit iterator to perform safe deletion during traversal
        auto& chain = buckets[idx];
        for (auto it = chain.begin(); it != chain.end(); ++it) {
            if (it->first == key) {
                chain.erase(it); // Key found, remove it from the chain
                return;
            }
        }
    }
};
