#include <vector>
#include <list>
#include <algorithm>

using namespace std;

class MyHashMap {
private:
    // Choosing a prime number significantly reduces the frequency of collisions
    static const int BUCKET_SIZE = 10007;
    
    // Core memory table: Array of linked lists storing {key, value} pairs
    vector<list<pair<int, int>>> buckets;

    // Helper: Polynomial hash indexing logic
    int getHashIndex(int key) {
        return key % BUCKET_SIZE;
    }

public:
    MyHashMap() {
        // Pre-allocate bucket structures
        buckets.resize(BUCKET_SIZE);
    }
    
    void put(int key, int value) {
        int idx = getHashIndex(key);
        
        // Iterate through the target bucket chain to check for existing keys
        for (auto& element : buckets[idx]) {
            if (element.first == key) {
                element.second = value; // Key found, update value instantly
                return;
            }
        }
        
        // Key doesn't exist, insert new entry at the end of the chain
        buckets[idx].push_back({key, value});
    }
    
    int get(int key) {
        int idx = getHashIndex(key);
        
        // Search inside the corresponding collision chain
        for (const auto& element : buckets[idx]) {
            if (element.first == key) {
                return element.second; // Return matched value
            }
        }
        
        return -1; // Standard marker for missing key layout
    }
    
    void remove(int key) {
        int idx = getHashIndex(key);
        
        auto& chain = buckets[idx];
        // Explicit iterator loop for dynamic safe removal while parsing nodes
        for (auto it = chain.begin(); it != chain.end(); ++it) {
            if (it->first == key) {
                chain.erase(it); // Erase node point, breaking links safely
                return;
            }
        }
    }
};

