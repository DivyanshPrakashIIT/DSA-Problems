#include <vector>
#include <queue>
#include <unordered_set>
#include <random>
#include <algorithm>

using namespace std;

class Solution {
private:
    // Zobrist Table: [position][value] -> 6 positions (0-5), 6 values (0-5)
    unsigned long long zobrist_table[6][6];
    
    // Adjacency list representing valid moves for the 0-th tile in a flattened 2x3 array
    // Index mapping:
    // 0 1 2
    // 3 4 5
    vector<vector<int>> neighbors = {
        {1, 3},       // From pos 0, we can go to 1 or 3
        {0, 2, 4},    // From pos 1, we can go to 0, 2, or 4
        {1, 5},       // From pos 2, we can go to 1 or 5
        {0, 4},       // From pos 3, we can go to 0 or 4
        {1, 3, 5},    // From pos 4, we can go to 1, 3, or 5
        {2, 4}        // From pos 5, we can go to 2 or 4
    };

    // Helper to generate the initial full hash of any board configuration
    unsigned long long computeFullHash(const vector<int>& board) {
        unsigned long long h = 0;
        for (int pos = 0; pos < 6; ++pos) {
            h ^= zobrist_table[pos][board[pos]];
        }
        return h;
    }

public:
    int slidingPuzzle(vector<vector<int>>& board) {
        // Initialize random number generator for Zobrist Keys
        mt19937_64 rng(2026);
        for (int i = 0; i < 6; ++i) {
            for (int j = 0; j < 6; ++j) {
                zobrist_table[i][j] = rng();
            }
        }

        // Target configurations flattened
        vector<int> target_board = {1, 2, 3, 4, 5, 0};
        unsigned long long target_hash = computeFullHash(target_board);

        // Flatten the initial 2D board input into 1D vector
        vector<int> start_board(6);
        int start_zero_pos = -1;
        int idx = 0;
        for (int r = 0; r < 2; ++r) {
            for (int c = 0; c < 3; ++c) {
                start_board[idx] = board[r][c];
                if (board[r][c] == 0) start_zero_pos = idx;
                idx++;
            }
        }

        unsigned long long start_hash = computeFullHash(start_board);

        // If the start board is already resolved
        if (start_hash == target_hash) return 0;

        // BFS Setup
        // Queue stores pair of: {current_board_state, position_of_zero}
        queue<pair<vector<int>, int>> q;
        unordered_set<unsigned long long> visited;

        q.push({start_board, start_zero_pos});
        visited.insert(start_hash);

        int moves = 0;

        while (!q.empty()) {
            int size = q.size();
            while (size--) {
                auto [curr_board, zero_pos] = q.front();
                q.pop();

                // Generate current hash to apply O(1) incremental swaps
                unsigned long long curr_hash = computeFullHash(curr_board);

                // Explore all valid adjacent moves for the blank tile (0)
                for (int next_pos : neighbors[zero_pos]) {
                    vector<int> next_board = curr_board;
                    int val_to_swap = next_board[next_pos];

                    // --- O(1) ZOBRIST HASH UPDATE ---
                    // 1. Remove old configurations from the hash
                    unsigned long long next_hash = curr_hash;
                    next_hash ^= zobrist_table[zero_pos][0];
                    next_hash ^= zobrist_table[next_pos][val_to_swap];

                    // Swap the elements physically in the array
                    swap(next_board[zero_pos], next_board[next_pos]);

                    // 2. Add new configurations into the hash
                    next_hash ^= zobrist_table[zero_pos][val_to_swap];
                    next_hash ^= zobrist_table[next_pos][0];

                    // Match Target check
                    if (next_hash == target_hash) return moves + 1;

                    // If this layout hasn't been visited, push to queue
                    if (!visited.count(next_hash)) {
                        visited.insert(next_hash);
                        q.push({next_board, next_pos});
                    }
                }
            }
            moves++;
        }

        return -1; // Unreachable target state
    }
};
