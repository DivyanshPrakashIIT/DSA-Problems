#include <unordered_map>
#include <random>

using namespace std;

class Solution {
private:
    mt19937_64 rng;
    
    // Random mapping layers for structural components
    unordered_map<int, unsigned long long> node_rand;
    unordered_map<unsigned long long, unsigned long long> left_rand;
    unordered_map<unsigned long long, unsigned long long> right_rand;
    
    // Target hash of the subRoot tree
    unsigned long long target_subroot_hash = 0;
    bool found_match = false;

    // Helper functions to fetch or generate pseudo-random keys
    unsigned long long get_node_rand(int val) {
        if (node_rand.find(val) == node_rand.end()) node_rand[val] = rng();
        return node_rand[val];
    }

    unsigned long long get_left_rand(unsigned long long h) {
        if (left_rand.find(h) == left_rand.end()) left_rand[h] = rng();
        return left_rand[h];
    }

    unsigned long long get_right_rand(unsigned long long h) {
        if (right_rand.find(h) == right_rand.end()) right_rand[h] = rng();
        return right_rand[h];
    }

    // Computes hash for any tree and optionally checks against target hash
    unsigned long long computeHash(TreeNode* node, bool check_match) {
        if (!node) return 0; // Base case: Null node hash is 0

        // Post-order: compute children hashes first
        unsigned long long left_hash = computeHash(node->left, check_match);
        unsigned long long right_hash = computeHash(node->right, check_match);

        // Standard Zobrist dynamic mix
        unsigned long long current_hash = get_node_rand(node->val) ^ 
                                         get_left_rand(left_hash) ^ 
                                         get_right_rand(right_hash);

        // If we are scanning the main tree, look for the target match
        if (check_match && current_hash == target_subroot_hash) {
            found_match = true;
        }

        return current_hash;
    }

public:
    bool isSubtree(TreeNode* root, TreeNode* subRoot) {
        // Deterministic seeding for LeetCode environment runtime
        rng.seed(2026);
        
        node_rand.clear();
        left_rand.clear();
        right_rand.clear();
        found_match = false;

        // Step 1: First, compute the absolute hash of the target subRoot tree
        target_subroot_hash = computeHash(subRoot, false);

        // Step 2: Now traverse the main tree and check if this hash exists anywhere
        computeHash(root, true);

        return found_match;
    }
};
