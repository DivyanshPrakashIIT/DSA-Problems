#include <vector>
#include <unordered_set>
#include <algorithm>
using namespace std;
class Solution {
private:
    const long long BASE1 = 100003;
    const long long BASE2 = 100019;
    const long long MOD1 = 1000000007;
    const long long MOD2 = 1000000009;
    inline long long combine(long long h1, long long h2) {
        return (h1 << 32) | h2;
    }
    bool hasCommonSubpath(int len, const vector<vector<int>>& paths) {
        long long power1 = 1;
        long long power2 = 1;
        for (int i = 0; i < len - 1; ++i) {
            power1 = (power1 * BASE1) % MOD1;
            power2 = (power2 * BASE2) % MOD2;
        }
        unordered_set<long long> common_hashes;
        for (int i = 0; i < paths.size(); ++i) {
            const auto& path = paths[i];
            if (path.size() < len) return false;
            unordered_set<long long> current_hashes;
            long long hash1 = 0, hash2 = 0;
            for (int j = 0; j < len; ++j) {
                hash1 = (hash1 * BASE1 + path[j]) % MOD1;
                hash2 = (hash2 * BASE2 + path[j]) % MOD2;
            }
            if (i == 0 || common_hashes.count(combine(hash1, hash2))) {
                current_hashes.insert(combine(hash1, hash2));
            }
            for (int j = len; j < path.size(); ++j) {
                hash1 = (hash1 - path[j - len] * power1 % MOD1 + MOD1) % MOD1;
                hash1 = (hash1 * BASE1 + path[j]) % MOD1;
                hash2 = (hash2 - path[j - len] * power2 % MOD2 + MOD2) % MOD2;
                hash2 = (hash2 * BASE2 + path[j]) % MOD2;
                long long combined = combine(hash1, hash2);
                if (i == 0 || common_hashes.count(combined)) {
                    current_hashes.insert(combined);
                }
            }
            if (i == 0) {
                common_hashes = move(current_hashes);
            } else {
                common_hashes = move(current_hashes);
                if (common_hashes.empty()) return false; 
            }
        }
        return !common_hashes.empty();
    }
public:
    int longestCommonSubpath(int n, vector<vector<int>>& paths) {
        int low = 1;
        int high = paths[0].size();
        for (const auto& path : paths) {
            high = min(high, (int)path.size());
        }
        int ans = 0;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (hasCommonSubpath(mid, paths)) {
                ans = mid;     
                low = mid + 1;
            } else {
                high = mid - 1; 
            }
        }
        return ans;
    }
};
